{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "write_file",
  "description": "Write text to a workspace file, creating or overwriting it. Paths are workspace-relative.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "path": { "type": "string", "minLength": 1 },
      "content": { "type": "string" }
    },
    "required": ["path", "content"],
    "additionalProperties": false
  }
}
